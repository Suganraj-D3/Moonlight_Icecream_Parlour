{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/menu.js",
      "dest": "api/index.js"
    },
    {
      "src": "/sales_summary.js",
      "dest": "api/index.js"
    },
    {
      "src": "/sales_endings.js",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
